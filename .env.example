# HiBot 環境變數範本；複製成 .env 後填入。
# ── 模型金鑰（用到哪家就填哪家）──────────────────────────
ANTHROPIC_API_KEY=      # 走 Claude 原廠時需要（預設設定用得到）
OPENROUTER_API_KEY=     # 走 OpenRouter 接各家模型時才需要
# OPENAI_API_KEY=       # 直連 OpenAI 官方時才需要

# ── 對接／安全（正式對外務必設 HIBOT_API_KEY）──────────────
HIBOT_API_KEY=          # 服務對接存取金鑰。設了才鎖 /api/*（需 Authorization: Bearer <金鑰>）；
                        # 未設＝開放，僅供本機開發。⚠ /api/config（可改機器人人設/門檻）未設金鑰時一律拒絕。
LLM_TIMEOUT_SECONDS=60  # LLM 呼叫逾時秒數（填非數字會被忽略、自動退回 60）
RUNTIME_CONFIG_PATH=data/runtime_config.json  # HiSupport 注入設定的存檔位置
# ENABLE_API_DOCS=      # 設 1/true 才開 FastAPI 互動文件(/docs/api、/openapi.json)；預設關閉

# ── 路徑（通常照預設即可）────────────────────────────────
DB_PATH=data/prototype.db
KB_DIR=data/kb
KB_INDEX_PATH=data/kb_index.json
FAQ_PATH=data/faq.json
MOCK_USERS_PATH=data/mock_users.json

# 註：模型「哪個等級用哪個模型」改在 config/models.toml，不在這裡。
